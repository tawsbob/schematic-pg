{
  "name": "postgrest-schema-dsl",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "editors/vscode",
    "editors/language-server"
  ],
  "exports": {
    "./schema-dsl": "./src/schema-dsl/index.ts"
  },
  "scripts": {
    "parse": "tsx src/schema-dsl/cli.ts",
    "tokenize": "tsx src/schema-dsl/cli.ts --tokens",
    "generate": "tsx src/sql-generator/cli.ts",
    "generate:client": "tsx src/db/generate-client-cli.ts",
    "generate:api": "tsx src/api-generator/generate-api-cli.ts",
    "dev:api": "npm run generate:client && npm run generate:api && tsx generated/app.ts",
    "setup:env": "test -f .env || cp .env.example .env",
    "db:ping": "tsx src/db/cli.ts",
    "db:bootstrap": "tsx src/db/bootstrap-cli.ts",
    "db:diff": "tsx src/db/diff-cli.ts",
    "db:migrate": "tsx src/db/migrate-cli.ts",
    "db:migrate:status": "tsx src/db/migrate-cli.ts status",
    "build:lsp": "npm run build --workspace=@postgrest/schema-dsl-language-server",
    "build:extension": "npm run vscode:prepublish --workspace=postgrest-schema-dsl-vscode && npm run package --workspace=postgrest-schema-dsl-vscode",
    "test": "node --import tsx --test 'src/**/__tests__/**/*.test.ts' 'editors/language-server/__tests__/**/*.test.ts'",
    "test:integration": "node --import tsx --test 'src/**/__tests__/**/*.integration.test.ts'",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f postgres",
    "docker:reset": "docker compose down -v && rm -rf docker_data/postgres && docker compose up -d"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "@hono/zod-validator": "^0.8.0",
    "hono": "^4.12.27",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  }
}
