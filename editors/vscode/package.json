{
  "name": "postgrest-schema-dsl-vscode",
  "displayName": "PostgREST Schema DSL",
  "description": "Syntax highlighting and language support for .schema files",
  "version": "0.1.0",
  "publisher": "postgrest",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "workspaceContains:**/*.schema",
    "onLanguage:schema-dsl"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "schema-dsl",
        "aliases": [
          "PostgREST Schema",
          "schema"
        ],
        "extensions": [
          ".schema"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "schema-dsl",
        "scopeName": "source.schema-dsl",
        "path": "./syntaxes/schema-dsl.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Schema DSL",
      "properties": {
        "schemaDsl.trace.server": {
          "scope": "window",
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the Schema DSL language server."
        }
      }
    }
  },
  "scripts": {
    "copy-assets": "node scripts/copy-assets.mjs",
    "build:lsp": "npm run build --workspace=@postgrest/schema-dsl-language-server",
    "compile": "npm run copy-assets && npm run build:lsp && node esbuild.mjs",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.25.5"
  }
}
